# ============================================
# Online Meeting Summarizer - Environment File
# Starlight Secondary School, Amuria District
# ============================================

# Database (PostgreSQL for Docker, SQLite for local dev)
DATABASE_URL=sqlite:///./meeting_summarizer.db
# DATABASE_URL=postgresql://starlight:StarlightDB2026!@localhost:5432/meeting_summarizer

# Redis (required for Celery worker; optional for local dev fallback)
REDIS_URL=redis://localhost:6379/0

# Security
SECRET_KEY=change-this-to-a-long-random-string-in-production

# Default Administrator Credentials (used on first startup)
ADMIN_EMAIL=admin@starlight.sc.ug
ADMIN_PASSWORD=Starlight2026!

# School Settings
SCHOOL_NAME=Starlight Secondary School
TIMEZONE=Africa/Kampala
WHISPER_MODEL=base

# Docker Compose DB Password
DB_PASSWORD=StarlightDB2026!

# Frontend API URL
NEXT_PUBLIC_API_URL=http://localhost:8000
